[gd_scene load_steps=3 format=3]

;; Main — the game entry point (run/main_scene). Owns the single persistent Embe
;; and bootstraps RoomManager, which adopts Embe and loads the first room.
;; Rooms do NOT embed an Embe; this scene is the sole owner.

[ext_resource type="Script" path="res://scripts/core/bootstrap.gd" id="1"]
[ext_resource type="PackedScene" uid="uid://bjobf1ixhsvuj" path="res://scenes/entities/embe/embe.tscn" id="2"]

[node name="Main" type="Node"]
script = ExtResource("1")

[node name="Embe" parent="." instance=ExtResource("2")]
scale = Vector2(0.5, 0.5)
