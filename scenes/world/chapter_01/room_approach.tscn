[gd_scene load_steps=14 format=3]

;; Room: Approach — Stoneback Shelf
;; The haulway connecting Arrival (sea cove) and the Foundry. A low-stakes
;; practice corridor: one AbsorbableObject of each form (basalt, driftwood,
;; coral, sea glass) lines the path so the player rehearses absorb/release
;; before the Foundry puzzle. One optional lore alcove (a hauler's cairn).
;;
;; Primary light source: ambient daylight from the sea-facing opening on the
;; LEFT. Light travels left → right; shadows fall to the RIGHT. No artificial
;; lights. CanvasModulate #C4A882 (warm overcast stone, matches the chapter).
;;
;; Greyboxed with StaticBody2D + ColorRect (same convention as room_foundry);
;; tilesets/sprites are the separate art gate and are intentionally absent.
;;
;; Every prop is motivated (who was here / what they left):
;;   - Basalt slab   : a chunk of fallen ceiling — Embe's own native stone.
;;   - Driftwood plank: a board off the workers' old tide-walkway.
;;   - Coral chunk    : tide-pool coral hauled up to feed the lime kilns.
;;   - Sea-glass shard: smoothed bottle-glass, a hauler's discard left to mark the bend.
;;   - Cairn waymark  : the tally-stone a hauler scratched on every trip.

[ext_resource type="Script" path="res://scripts/world/room_approach.gd" id="1_room"]
[ext_resource type="Script" path="res://scripts/components/door_trigger.gd" id="2_door"]
[ext_resource type="Script" path="res://scripts/components/absorbable_object.gd" id="3_absorb"]
[ext_resource type="Script" path="res://scripts/components/lore_pickup.gd" id="4_lore"]
[ext_resource type="Resource" path="res://resources/lore/approach_haulers_waymark.tres" id="5_loredata"]
[ext_resource type="Resource" path="res://resources/materials/basalt.tres" id="6_basalt"]
[ext_resource type="Resource" path="res://resources/materials/driftwood.tres" id="7_driftwood"]
[ext_resource type="Resource" path="res://resources/materials/coral.tres" id="8_coral"]
[ext_resource type="Resource" path="res://resources/materials/sea_glass.tres" id="9_seaglass"]

[sub_resource type="RectangleShape2D" id="ground_shape"]
size = Vector2(1600, 40)

[sub_resource type="RectangleShape2D" id="door_shape"]
size = Vector2(40, 80)

[sub_resource type="RectangleShape2D" id="absorb_shape"]
size = Vector2(30, 30)

[sub_resource type="RectangleShape2D" id="lore_shape"]
size = Vector2(32, 40)

;; ═══════════════════════════════════════════════════
;; ROOT
;; ═══════════════════════════════════════════════════

[node name="RoomApproach" type="Node2D"]
script = ExtResource("1_room")

[node name="CanvasModulate" type="CanvasModulate" parent="."]
color = Color(0.769, 0.659, 0.51, 1.0)

;; ── Parallax Background ─────────────────────────────
[node name="ParallaxBackground" type="ParallaxBackground" parent="."]

[node name="FarLayer" type="ParallaxLayer" parent="ParallaxBackground"]
motion_scale = Vector2(0.2, 0.2)

[node name="MidLayer" type="ParallaxLayer" parent="ParallaxBackground"]
motion_scale = Vector2(0.5, 0.5)

[node name="NearLayer" type="ParallaxLayer" parent="ParallaxBackground"]
motion_scale = Vector2(0.8, 0.8)

;; ═══════════════════════════════════════════════════
;; TERRAIN — greybox collision geometry
;; ═══════════════════════════════════════════════════

[node name="Terrain" type="Node2D" parent="."]

;; Ground floor spanning the corridor (top edge at y=420)
[node name="GroundBody" type="StaticBody2D" parent="Terrain"]
position = Vector2(760, 440)
collision_layer = 1

[node name="GroundShape" type="CollisionShape2D" parent="Terrain/GroundBody"]
shape = SubResource("ground_shape")

[node name="GroundVisual" type="ColorRect" parent="Terrain/GroundBody"]
offset_left = -800.0
offset_top = -20.0
offset_right = 800.0
offset_bottom = 60.0
color = Color(0.35, 0.3, 0.25, 1.0)

;; Cairn nook backdrop at the bend — frames the lore waymark (decorative)
[node name="CairnNookVisual" type="ColorRect" parent="Terrain"]
offset_left = 1248.0
offset_top = 350.0
offset_right = 1312.0
offset_bottom = 420.0
color = Color(0.3, 0.27, 0.24, 1.0)

;; ═══════════════════════════════════════════════════
;; ENTITIES — AbsorbableObjects (practice forms)
;; ═══════════════════════════════════════════════════

[node name="Entities" type="Node2D" parent="."]
y_sort_enabled = true

;; ── Basalt slab (fallen ceiling chunk — Embe's native stone) ──
[node name="BasaltSlab" type="Node2D" parent="Entities"]
position = Vector2(320, 400)

[node name="AbsorbableObject" type="Area2D" parent="Entities/BasaltSlab"]
collision_layer = 4
collision_mask = 2
script = ExtResource("3_absorb")
material_profile = ExtResource("6_basalt")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Entities/BasaltSlab/AbsorbableObject"]
shape = SubResource("absorb_shape")

[node name="Visual" type="ColorRect" parent="Entities/BasaltSlab/AbsorbableObject"]
offset_left = -15.0
offset_top = -15.0
offset_right = 15.0
offset_bottom = 15.0
color = Color(0.65, 0.62, 0.58, 1.0)

[node name="Label" type="Label" parent="Entities/BasaltSlab/AbsorbableObject"]
offset_left = -25.0
offset_top = -35.0
offset_right = 25.0
offset_bottom = -15.0
text = "BASALT"
horizontal_alignment = 1

;; ── Driftwood plank (board off the workers' tide-walkway) ──
[node name="DriftwoodPlank" type="Node2D" parent="Entities"]
position = Vector2(560, 400)

[node name="AbsorbableObject" type="Area2D" parent="Entities/DriftwoodPlank"]
