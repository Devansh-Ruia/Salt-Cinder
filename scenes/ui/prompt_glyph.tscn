[gd_scene load_steps=2 format=3]

;; PromptGlyph — reusable glyphs-only teaching cue. Placeholder keycap in a
;; rounded panel; swap `icon_texture` on the script for final art. # TODO: art gate

[ext_resource type="Script" path="res://scripts/ui/prompt_glyph.gd" id="1"]

[sub_resource type="StyleBoxFlat" id="keycap"]
bg_color = Color(0.11, 0.1, 0.09, 0.82)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.85, 0.8, 0.68, 0.85)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

[node name="PromptGlyph" type="Control"]
mouse_filter = 2
script = ExtResource("1")

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 0
theme_override_styles/panel = SubResource("keycap")

[node name="Margin" type="MarginContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/margin_left = 6
theme_override_constants/margin_top = 4
theme_override_constants/margin_right = 6
theme_override_constants/margin_bottom = 4

[node name="Icon" type="TextureRect" parent="Panel/Margin"]
visible = false
layout_mode = 2
custom_minimum_size = Vector2(22, 22)
expand_mode = 1
stretch_mode = 5

[node name="KeyLabel" type="Label" parent="Panel/Margin"]
layout_mode = 2
custom_minimum_size = Vector2(18, 22)
theme_override_colors/font_color = Color(0.95, 0.92, 0.84, 1.0)
theme_override_font_sizes/font_size = 16
text = "E"
horizontal_alignment = 1
vertical_alignment = 1
