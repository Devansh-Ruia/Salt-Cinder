;; ═══════════════════════════════════════════════════
;; DOORS — direct children of root (RoomManager scans root for get_door_id)
;; ═══════════════════════════════════════════════════

;; ── Back to Arrival (left) ──
[node name="DoorToArrival" type="Area2D" parent="."]
