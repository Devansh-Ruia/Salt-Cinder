[node name="Visual" type="ColorRect" parent="Entities/DriftwoodPlank/AbsorbableObject"]
offset_left = -15.0
offset_top = -15.0
offset_right = 15.0
offset_bottom = 15.0
color = Color(0.82, 0.75, 0.6, 1.0)

[node name="Label" type="Label" parent="Entities/DriftwoodPlank/AbsorbableObject"]
offset_left = -35.0
offset_top = -35.0
offset_right = 35.0
offset_bottom = -15.0
text = "DRIFTWOOD"
horizontal_alignment = 1

;; ── Coral chunk (tide-pool coral hauled up for the lime kilns) ──
[node name="CoralChunk" type="Node2D" parent="Entities"]
position = Vector2(800, 400)

[node name="AbsorbableObject" type="Area2D" parent="Entities/CoralChunk"]
collision_layer = 4
collision_mask = 2
