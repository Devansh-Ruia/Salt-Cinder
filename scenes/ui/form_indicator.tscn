[gd_scene load_steps=3 format=3]

;; FormIndicator — persistent placeholder form readout (bottom-left). The
;; symbol + short label are temporary legibility aids; final art can replace Icon.

[ext_resource type="Script" path="res://scripts/ui/form_indicator.gd" id="1"]

[sub_resource type="StyleBoxFlat" id="fi_panel"]
bg_color = Color(0.11, 0.1, 0.09, 0.7)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.76, 0.66, 0.51, 0.7)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6
content_margin_left = 6.0
content_margin_top = 6.0
content_margin_right = 6.0
content_margin_bottom = 6.0

[node name="FormIndicator" type="Control"]
anchors_preset = 2
anchor_top = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = -64.0
offset_right = 204.0
offset_bottom = -16.0
grow_vertical = 0
script = ExtResource("1")

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 0
theme_override_styles/panel = SubResource("fi_panel")

[node name="HBox" type="HBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Swatch" type="ColorRect" parent="Panel/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(32, 32)
color = Color(0.65, 0.62, 0.58, 1.0)

[node name="Icon" type="TextureRect" parent="Panel/HBox"]
visible = false
layout_mode = 2
custom_minimum_size = Vector2(28, 28)
expand_mode = 1
stretch_mode = 5

[node name="SymbolLabel" type="Label" parent="Panel/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(36, 32)
theme_override_colors/font_color = Color(0.96, 0.93, 0.84, 1.0)
theme_override_font_sizes/font_size = 20
text = "[]"
horizontal_alignment = 1
vertical_alignment = 1

[node name="FormLabel" type="Label" parent="Panel/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(86, 32)
theme_override_colors/font_color = Color(0.96, 0.93, 0.84, 1.0)
theme_override_font_sizes/font_size = 15
text = "BASALT"
vertical_alignment = 1
